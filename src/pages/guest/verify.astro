---
export const prerender = false;
import Layout from "@/layouts/Layout.astro";
import { createServiceRoleClient } from "@/lib/supabase";
import { SignJWT } from "jose";
import { GUEST_SESSION_SECRET } from "astro:env/server";

// Already authenticated — send to panel
if (Astro.locals.guestToken) {
  return Astro.redirect("/guest/panel", 302);
}

const token = Astro.url.searchParams.get("token");

const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;

type View = "instruction" | "expired" | "invalid";

let view: View = "invalid";

if (token && UUID_RE.test(token)) {
  const supabase = createServiceRoleClient();
  if (supabase) {
    const { data: row } = await supabase
      .from("guest_tokens")
      .select("id, check_out_date")
      .eq("token_value", token)
      .maybeSingle();

    if (row) {
      const today = new Date().toISOString().slice(0, 10);
      if (row.check_out_date < today) {
        view = "expired";
      } else {
        // Issue pending_guest cookie
        const secret = new TextEncoder().encode(GUEST_SESSION_SECRET ?? "");
        const pendingJwt = await new SignJWT({ tokenId: row.id, type: "pending_guest" })
          .setProtectedHeader({ alg: "HS256" })
          .setExpirationTime("10m")
          .sign(secret);

        Astro.cookies.set("pending_guest", pendingJwt, {
          httpOnly: true,
          secure: true,
          sameSite: "lax",
          path: "/",
          maxAge: 600,
        });

        view = "instruction";
      }
    }
    // No row → view stays "invalid" (same as unknown token — avoids UUID enumeration)
  }
}
// Missing/invalid token format → view stays "invalid"
---

<Layout title="Guest Access">
  <div class="flex min-h-screen items-center justify-center bg-gray-50 px-4">
    <div class="w-full max-w-md rounded-xl border border-gray-200 bg-white p-8 text-center shadow-sm">
      {
        view === "instruction" && (
          <>
            <div class="mb-4 text-5xl">📱</div>
            <h1 class="mb-2 text-xl font-semibold text-gray-900">Step 2 of 2</h1>
            <p class="text-gray-600">Scan the QR code in your room to complete access.</p>
          </>
        )
      }
      {
        view === "expired" && (
          <>
            <div class="mb-4 text-4xl">⏰</div>
            <h1 class="mb-2 text-xl font-semibold text-gray-900">Access Expired</h1>
            <p class="text-gray-600">Your stay access has expired — please ask reception for assistance.</p>
          </>
        )
      }
      {
        view === "invalid" && (
          <>
            <div class="mb-4 text-4xl">🚫</div>
            <h1 class="mb-2 text-xl font-semibold text-gray-900">Access Unavailable</h1>
            <p class="text-gray-600">Access not available — please contact reception.</p>
          </>
        )
      }
    </div>
  </div>
</Layout>
