---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import MobileNav from "@/components/staff/MobileNav";

interface Props {
  title: string;
}

const { title } = Astro.props;

const supabase = createClient(Astro.request.headers, Astro.cookies);
let pendingCount = 0;
if (supabase) {
  const { count } = await supabase.from("orders").select("*", { count: "exact", head: true }).eq("status", "pending");
  pendingCount = count ?? 0;
}
---

<Layout title={title}>
  <div class="bg-cosmic min-h-screen">
    <nav
      class="flex items-center justify-between border-b border-white/10 bg-black/20 px-6 py-4 backdrop-blur-sm print:hidden"
    >
      <span class="text-lg font-bold text-white">RoomPilot</span>
      <button
        class="flex min-h-[44px] min-w-[44px] items-center justify-center text-white md:hidden"
        onclick="window.dispatchEvent(new CustomEvent('mobile-nav-open'))"
        aria-label="Open navigation"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
      <div class="hidden items-center gap-4 md:flex">
        <a href="/dashboard/generate-token" class="text-sidebar-foreground text-sm transition-colors hover:text-white">
          Generate Token
        </a>
        <a
          href="/dashboard"
          class="text-sidebar-foreground flex items-center gap-1.5 text-sm transition-colors hover:text-white"
        >
          Orders
          <span
            id="pending-badge"
            class:list={[
              "bg-destructive flex h-5 min-w-5 items-center justify-center rounded-full px-1.5 text-xs font-bold text-white",
              { hidden: pendingCount === 0 },
            ]}
          >
            {pendingCount}
          </span>
        </a>
        <form method="POST" action="/api/auth/signout">
          <button
            type="submit"
            class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm text-white transition-colors hover:bg-white/20"
          >
            Sign Out
          </button>
        </form>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <MobileNav client:load pendingCount={pendingCount} currentPath={Astro.url.pathname} />
  </div>
  <script>
    window.addEventListener("pending-count-update", (e) => {
      const badge = document.getElementById("pending-badge");
      if (!badge) return;
      const count = (e as CustomEvent<number>).detail;
      badge.textContent = String(count);
      badge.classList.toggle("hidden", count === 0);
    });
  </script>
</Layout>
