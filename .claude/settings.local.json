{
  "permissions": {
    "allow": [
      "PowerShell(Set-Clipboard *)",
      "Skill(10x-bootstrapper)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Read",
      "Edit",
      "Write",
      "PowerShell(New-Item *)",
      "Bash(Get-ChildItem -Path \"C:\\\\data\\\\_10xdev\\\\room_pilot\" -Force)",
      "Bash(Select-Object Name, PSIsContainer)",
      "PowerShell(Get-ChildItem -Path \"C:\\\\data\\\\_10xdev\\\\room_pilot\" -Force | Select-Object Name, @{Name=\"IsDirectory\"; Expression={$_.PSIsContainer}})",
      "Bash(git -C \"C:\\\\data\\\\_10xdev\\\\room_pilot\" worktree list)",
      "Bash(Get-Content \"C:\\\\data\\\\_10xdev\\\\room_pilot\\\\CLAUDE.md\" -Raw)",
      "Bash(Select-Object -First 200)",
      "PowerShell(\\(Get-Item \"C:\\\\data\\\\_10xdev\\\\room_pilot\\\\CLAUDE.md\"\\).Length; \\(Get-Content \"C:\\\\data\\\\_10xdev\\\\room_pilot\\\\CLAUDE.md\" | Measure-Object -Line\\).Lines)",
      "Bash(echo \"exit:$?\")",
      "Bash(dir \"C:\\\\data\\\\_10xdev\\\\room_pilot\\\\src\\\\pages\\\\api\")",
      "PowerShell([System.DateTime]::UtcNow.ToString\\(\"yyyy-MM-ddTHH:mm:ssZ\"\\))",
      "Skill(10x-plan)",
      "Bash(echo \"exit: $?\")",
      "Bash(not exist *)",
      "Skill(10x-impl-review)",
      "Skill(10x-implement)",
      "Bash(echo \"empty: $?\")",
      "Bash(grep -v \"^$\")",
      "Bash(Set-Clipboard \"/10x-implement testing-runner-qr-auth-path phase 3\")",
      "Bash(taskkill /F /FI \"WINDOWTITLE eq supabase*\")",
      "Bash(Get-Process -Name \"supabase\" -ErrorAction SilentlyContinue)",
      "Bash(Stop-Process -Force)",
      "Bash(Write-Host \"done\")",
      "PowerShell(Get-Process *)",
      "PowerShell(head *)",
      "PowerShell(sort *)"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ],
    "ask": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push *)",
      "Bash(git push)"
    ]
  },
   "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --fix . --quiet",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "npx tsc --noEmit",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": "bash -c 'FILE=$(jq -r .tool_input.file_path) && npx vitest related \"$FILE\" --run'",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
